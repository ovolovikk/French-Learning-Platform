## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Local History for Visual Studio Code
.history/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Core Crumps
core.[0-9]*

# Web workbench (sass)
.sass-cache/

# User-specific files (JetBrains Rider)
.idea/
*.sln.iml

# Microsoft Azure Web App publish settings. Comment out to save publish settings to repo
*.PublishSettings

# Mac
.DS_Store

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.nuget
*.nupkg
*.snupkg
*.nuspec
*.stub
project.lock.json

# StyleCop
StyleCop.Cache

# Visual Studio 6 build log
*.plg

# Visual Studio 6 workspace options file
*.opt

# Visual Studio 6 auto-generated workspace file (contains which files were open etc.)
*.vbw

# Visual Studio LightSwitch build output
**/*.HTMLClient/GeneratedArtifacts
**/*.DesktopClient/GeneratedArtifacts
**/*.Server/GeneratedArtifacts

# Microsoft Office Temporary Files
~$*

# Parcel
.cache/
dist/

# NuGet Configs
nuget.config

# NCrunch
_NCunch_*
.*crunch*.local.xml
nCrunchTemp_*

# DotCover is a Code Coverage Tool
*.dotCover

# AxoCover is a Code Coverage Tool
.axoCover/*
!.axoCover/settings.json

# Coverlet is a free, cross platform Code Coverage Tool
coverage*.json
coverage*.xml
coverage*.info

# Qt Creator
*.pro.user

# Internal (Private) configurations
appsettings.Development.json
secrets.json
appsettings.json
appsettings.json

# User specific files (Visual Studio for Mac)
.DS_Store

# Rider
.idea/

# Dotnet Core
project.assets.json
