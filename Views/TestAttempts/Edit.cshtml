@model FrenchLearningPlatform.Domain.Model.TestAttempt

@{
    ViewData["Title"] = "Редагування спроби";
}

<h1>Редагувати спробу</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="TestId" class="form-label">Тест</label>
                <select asp-for="TestId" class="form-select" asp-items="ViewBag.Tests">
                    <option value="">— оберіть тест —</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" class="form-control" type="number" min="0" max="100" />
            </div>

            <div class="mb-3">
                <label asp-for="MistakesJsonb" class="form-label"></label>
                <textarea asp-for="MistakesJsonb" class="form-control font-monospace" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="CompletedAt" class="form-label"></label>
                <input asp-for="CompletedAt" class="form-control" type="datetime-local" />
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Зберегти" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
