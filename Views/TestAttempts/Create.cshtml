@model FrenchLearningPlatform.Domain.Model.TestAttempt

@{
    ViewData["Title"] = "Нова спроба тесту";
}

<h1>Нова спроба</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="TestId" class="form-label">Тест</label>
                <select asp-for="TestId" class="form-select" asp-items="ViewBag.Tests">
                    <option value="">— оберіть тест —</option>
                </select>
                <span asp-validation-for="TestId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label">Результат (балів)</label>
                <input asp-for="Score" class="form-control" type="number" min="0" max="100" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MistakesJsonb" class="form-label">Помилки (JSON, необов'язково)</label>
                <textarea asp-for="MistakesJsonb" class="form-control" rows="3" placeholder='{"word_id": 1}'></textarea>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Зберегти" class="btn btn-primary" />
                @if (ViewBag.ReturnTestId != null)
                {
                    <a asp-controller="Tests" asp-action="Details" asp-route-id="@ViewBag.ReturnTestId" class="btn btn-secondary">Скасувати</a>
                }
                else
                {
                    <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
