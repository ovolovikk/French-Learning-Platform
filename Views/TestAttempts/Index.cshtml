@model IEnumerable<FrenchLearningPlatform.Domain.Model.TestAttempt>

@{
    ViewData["Title"] = "Спроби тестів";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>
        Спроби тестів
        @if (ViewBag.TestTitle != null)
        {
            <small class="text-muted fs-5">— @ViewBag.TestTitle</small>
        }
    </h1>
    <a asp-action="Create" asp-route-testId="@ViewBag.TestId" class="btn btn-primary">+ Нова спроба</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Студент</th>
            <th>@Html.DisplayNameFor(model => model.Score)</th>
            <th>Тест</th>
            <th>@Html.DisplayNameFor(model => model.CompletedAt)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @using System.Text.Json
        @foreach (var item in Model)
        {
            int correctAnsw = item.Score ?? 0;
            int wrongAnsw = 0;
            if (!string.IsNullOrWhiteSpace(item.MistakesJsonb))
            {
                try
                {
                    var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                    var parsed = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(item.MistakesJsonb, options);
                    if (parsed != null) wrongAnsw = parsed.Count;
                }
                catch {}
            }
            int tot = correctAnsw + wrongAnsw;
            int pct = tot > 0 ? (int)Math.Round((double)correctAnsw / tot * 100) : 0;

            <tr>
                <td>@item.User?.Email</td>
                <td>
                    <span class="badge @(pct >= 80 ? "bg-success" : pct >= 50 ? "bg-warning text-dark" : "bg-danger")">
                        @correctAnsw / @(tot > 0 ? tot.ToString() : "?") (@pct%)
                    </span>
                </td>
                <td>
                    <a asp-controller="Tests" asp-action="Details" asp-route-id="@item.TestId">
                        @item.Test?.Title
                    </a>
                </td>
                <td>@item.CompletedAt?.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>
