@model French_Learning_Platform.ViewModels.ChangeRoleViewModel

@{
    ViewData["Title"] = "Зміна ролі";
}

<h1>Зміна ролі</h1>
<p class="text-muted">Користувач: <strong>@Model.UserEmail</strong></p>

<div class="row">
    <div class="col-md-5">
        <form method="post" asp-action="Edit">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserEmail" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="SelectedRole" class="form-label"></label>
                <select asp-for="SelectedRole" class="form-select">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
                <span asp-validation-for="SelectedRole" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Зберегти</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
