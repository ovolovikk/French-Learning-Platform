@model IEnumerable<FrenchLearningPlatform.Domain.Model.User>

@{
    ViewData["Title"] = "Користувачі та ролі";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Користувачі та ролі</h1>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">← На головну</a>
</div>

@if (TempData["RoleChanged"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["RoleChanged"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Email</th>
            <th>Роль</th>
            <th>Створено</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>
                    <span class="badge @(user.Role == AppRoles.Teacher ? "bg-warning text-dark" : "bg-info text-dark")">
                        @(user.Role == AppRoles.Teacher ? "Teacher" : "Student")
                    </span>
                </td>
                <td>@user.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Змінити роль</a>
                </td>
            </tr>
        }
    </tbody>
</table>
