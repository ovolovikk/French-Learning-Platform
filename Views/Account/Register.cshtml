@model French_Learning_Platform.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-3">Реєстрація нового акаунта</h2>

        <form method="post" asp-action="Register">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label d-block"></label>
                <div class="form-check form-check-inline">
                    <input asp-for="Role" class="form-check-input" type="radio" value="Student" id="roleStudent" />
                    <label class="form-check-label" for="roleStudent">Student</label>
                </div>
                <div class="form-check form-check-inline">
                    <input asp-for="Role" class="form-check-input" type="radio" value="Teacher" id="roleTeacher" />
                    <label class="form-check-label" for="roleTeacher">Teacher</label>
                </div>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PasswordConfirm" class="form-label"></label>
                <input asp-for="PasswordConfirm" class="form-control" />
                <span asp-validation-for="PasswordConfirm" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Зареєструватися</button>
                <a asp-action="Login" class="btn btn-outline-secondary">Вже маю акаунт</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
