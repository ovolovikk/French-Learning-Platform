@model FrenchLearningPlatform.Domain.Model.Category

@{
    ViewData["Title"] = "Деталі категорії";
}

<h1>@Model.Name</h1>
<hr />
<dl class="row">
    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Description)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>
</dl>

<div class="d-flex gap-2 mb-4">
    @if (User.IsInRole(AppRoles.Teacher))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
    }
    <a asp-action="Index" class="btn btn-secondary">← Назад до списку</a>
    @if (User.IsInRole(AppRoles.Teacher))
    {
        <form asp-action="ClearWords" asp-route-id="@Model.Id" method="post" class="d-inline"
              onsubmit="return confirm('Видалити всі слова категорії «@Model.Name»?');">
            <button type="submit" class="btn btn-outline-danger">🗑 Очистити всі слова</button>
        </form>
    }
</div>

@if (ViewBag.ClearResult != null)
{
    <div class="alert alert-warning alert-dismissible fade show">
        @ViewBag.ClearResult
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Слова у категорії (@Model.Words.Count)</h3>
    @if (User.IsInRole(AppRoles.Teacher))
    {
        <a asp-controller="Words" asp-action="Create" asp-route-categoryId="@Model.Id" class="btn btn-primary">+ Додати слово</a>
    }
</div>

@if (Model.Words.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-light">
            <tr>
                <th>Французьке слово</th>
                <th>Переклад</th>
                <th>Рівень складності</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var word in Model.Words)
            {
                <tr>
                    <td><a asp-controller="Words" asp-action="Details" asp-route-id="@word.Id">@word.FrenchTerm</a></td>
                    <td>@word.Translation</td>
                    <td>@word.DifficultyLevel</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Слів ще немає.</p>
}

<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Тести у категорії (@Model.Tests.Count)</h3>
    @if (User.IsInRole(AppRoles.Teacher))
    {
        <a asp-controller="Tests" asp-action="Create" asp-route-categoryId="@Model.Id" class="btn btn-primary">+ Створити тест</a>
    }
</div>

@if (Model.Tests.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-light">
            <tr>
                <th>Назва тесту</th>
                <th>Кількість слів</th>
                <th>Ліміт часу (сек)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var test in Model.Tests)
            {
                <tr>
                    <td><a asp-controller="Tests" asp-action="Details" asp-route-id="@test.Id">@test.Title</a></td>
                    <td>@test.Words</td>
                    <td>@test.TimeLimitSeconds</td>
                    <td>
                        @if (User.IsInRole(AppRoles.Teacher))
                        {
                            <a asp-controller="Tests" asp-action="Edit" asp-route-id="@test.Id" class="btn btn-sm btn-warning">Редагувати</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Тестів ще немає.</p>
}
