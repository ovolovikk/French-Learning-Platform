@model IEnumerable<FrenchLearningPlatform.Domain.Model.Word>

@{
    ViewData["Title"] = "Словник";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>
            Словник
            @if (ViewBag.CategoryName != null)
            {
                <small class="text-muted fs-5">— @ViewBag.CategoryName</small>
            }
        </h1>
    </div>
    <div class="d-flex gap-2">
        @if (ViewBag.CategoryId != null)
        {
            <a asp-controller="Categories" asp-action="Details" asp-route-id="@ViewBag.CategoryId" class="btn btn-outline-secondary">← Категорія</a>
        }
        @if (User.IsInRole(AppRoles.Teacher))
        {
            <a asp-action="ImportCsv" asp-route-categoryId="@ViewBag.CategoryId" class="btn btn-outline-success">⬆ Імпорт CSV</a>
            <a asp-action="Export"
               asp-route-categoryId="@ViewBag.CategoryId"
               asp-route-searchString="@ViewBag.SearchString"
               asp-route-difficulty="@ViewBag.Difficulty"
               asp-route-onlyFavorites="@ViewBag.OnlyFavorites"
               class="btn btn-outline-primary">⬇ Експорт Excel</a>
            <a asp-action="Create" asp-route-categoryId="@ViewBag.CategoryId" class="btn btn-primary">+ Нове слово</a>
        }
    </div>
</div>

<form id="wordsFiltersForm" method="get" class="row g-2 mb-4 align-items-center">
    <div class="col-md-3">
        <select id="categoryId" name="categoryId" class="form-select" asp-items="ViewBag.Categories">
            <option value="">-- Усі категорії --</option>
        </select>
    </div>
    <div class="col-md-4">
        <input id="searchString" type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Пошук за словом або перекладом..." />
    </div>
    <div class="col-md-3">
        <select id="difficulty" name="difficulty" class="form-select">
            <option value="">-- Усі рівні складності --</option>
            @for (int i = 1; i <= 5; i++)
            {
                if (ViewBag.Difficulty != null && ViewBag.Difficulty == i)
                {
                    <option value="@i" selected>@i @(i == 1 ? "зірка" : i > 1 && i < 5 ? "зірки" : "зірок")</option>
                }
                else
                {
                    <option value="@i">@i @(i == 1 ? "зірка" : i > 1 && i < 5 ? "зірки" : "зірок")</option>
                }
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Шукати</button>
    </div>
    @if (ViewBag.CanUseFavorites == true)
    {
        <div class="col-md-12">
            <div class="form-check mt-1">
                <input class="form-check-input" type="checkbox" id="onlyFavorites" name="onlyFavorites" value="true" @(ViewBag.OnlyFavorites == true ? "checked" : null) />
                <label class="form-check-label" for="onlyFavorites">Показати тільки улюблені слова</label>
            </div>
        </div>
    }
</form>

@if (ViewBag.ImportResult != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @ViewBag.ImportResult
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["FavMsg"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["FavMsg"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.FrenchTerm)</th>
            <th>@Html.DisplayNameFor(model => model.Translation)</th>
            <th>@Html.DisplayNameFor(model => model.DifficultyLevel)</th>
            <th>Категорія</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.FrenchTerm</strong></td>
                <td>@item.Translation</td>
                <td>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="@(i <= (item.DifficultyLevel ?? 0) ? "text-warning" : "text-muted")">★</span>
                    }
                </td>
                <td>
                    <a asp-controller="Categories" asp-action="Details" asp-route-id="@item.CategoryId">
                        @item.Category?.Name
                    </a>
                </td>
                <td>
                    @if (ViewBag.CanUseFavorites == true)
                    {
                        <form asp-controller="Favorites" asp-action="Toggle" method="post" class="d-inline">
                            <input type="hidden" name="wordId" value="@item.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            @{
                                bool isFav = (ViewBag.FavoriteWordIds as HashSet<int>)?.Contains(item.Id) == true;
                            }
                            <button type="submit" class="btn btn-sm @(isFav ? "btn-warning" : "btn-outline-secondary")" title="@(isFav ? "Прибрати з улюблених" : "До улюблених")">⭐</button>
                        </form>
                    }
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                    @if (User.IsInRole(AppRoles.Teacher))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById('wordsFiltersForm');
            if (!form) return;

            const categorySelect = document.getElementById('categoryId');
            const difficultySelect = document.getElementById('difficulty');
            const onlyFavoritesCheckbox = document.getElementById('onlyFavorites');

            [categorySelect, difficultySelect, onlyFavoritesCheckbox].forEach((el) => {
                if (el) {
                    el.addEventListener('change', () => form.submit());
                }
            });
        })();
    </script>
}

