@model FrenchLearningPlatform.Domain.Model.Word

@{
    ViewData["Title"] = Model.FrenchTerm;
}

<h1>@Model.FrenchTerm</h1>
<hr />
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Translation)</dt>
    <dd class="col-sm-9"><strong>@Html.DisplayFor(model => model.Translation)</strong></dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DifficultyLevel)</dt>
    <dd class="col-sm-9">
        @for (int i = 1; i <= 5; i++)
        {
            <span class="@(i <= (Model.DifficultyLevel ?? 0) ? "text-warning" : "text-muted")" style="font-size:1.4rem">★</span>
        }
        (@Model.DifficultyLevel / 5)
    </dd>

    <dt class="col-sm-3">Категорія</dt>
    <dd class="col-sm-9">
        <a asp-controller="Categories" asp-action="Details" asp-route-id="@Model.CategoryId">
            @Model.Category?.Name
        </a>
    </dd>
</dl>

<div class="d-flex gap-2">
    @if (User.IsInRole(AppRoles.Teacher))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Видалити</a>
    }
    <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-secondary">← Назад до словника</a>
</div>
