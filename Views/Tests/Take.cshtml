@model FrenchLearningPlatform.Domain.Model.Test
@using FrenchLearningPlatform.Domain.Model

@{
    ViewData["Title"] = $"Проходження тесту: {Model.Title}";
    var words = ViewBag.TestWords as List<Word> ?? new List<Word>();
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Впишіть переклад українською мовою:</h2>
            @if (Model.TimeLimitSeconds.HasValue && Model.TimeLimitSeconds > 0)
            {
                <div class="fs-4 fw-bold text-danger bg-white p-2 border rounded shadow-sm">
                    <i class="bi bi-clock"></i> <span id="time-left"></span>
                </div>
            }
        </div>
        
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">@Model.Title</h4>
            </div>
            <div class="card-body">
                <form id="test-form" asp-action="SubmitTest" method="post">
                    <input type="hidden" name="testId" value="@Model.Id" />
                    
                    @if (!words.Any())
                    {
                        <div class="alert alert-warning">Для цього тесту не знайдено слів. Перевірте категорію.</div>
                    }
                    else
                    {
                        for (int i = 0; i < words.Count; i++)
                        {
                            var word = words[i];
                            <div class="mb-4 pb-3 border-bottom">
                                <label class="form-label fs-5 fw-bold text-primary">@word.FrenchTerm</label>
                                <input type="text" name="word_@word.Id" class="form-control form-control-lg" placeholder="Ваш переклад" autocomplete="off" required />
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                            <button id="submit-btn" type="submit" class="btn btn-success btn-lg">Завершити та перевірити</button>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (Model.TimeLimitSeconds.HasValue && Model.TimeLimitSeconds > 0)
    {
        <script>
            // Таймер для тесту
            let timeRemaining = @Model.TimeLimitSeconds.Value;
            const timerElement = document.getElementById('time-left');
            const testForm = document.getElementById('test-form');
            
            function updateTimerDisplay() {
                const minutes = Math.floor(timeRemaining / 60);
                const seconds = timeRemaining % 60;
                if(timerElement) {
                    timerElement.innerText = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                }
            }

            function forceSubmitTest() {
                // Видаляємо required з усіх інпутів, щоб дозволити пусті поля при сабміті по тайм ауту
                const inputs = testForm.querySelectorAll('input[required]');
                inputs.forEach(input => input.removeAttribute('required'));
                testForm.submit();
            }

            const timerInterval = setInterval(() => {
                timeRemaining--;
                updateTimerDisplay();

                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    if(timerElement) {
                        timerElement.innerText = "00:00";
                    }
                    forceSubmitTest();
                }
            }, 1000);

            // Початковий виклик
            updateTimerDisplay();
        </script>
    }
}
