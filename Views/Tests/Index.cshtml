@model IEnumerable<FrenchLearningPlatform.Domain.Model.Test>

@{
    ViewData["Title"] = "Тести";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>
            Тести
            @if (ViewBag.CategoryName != null)
            {
                <small class="text-muted fs-5">— @ViewBag.CategoryName</small>
            }
        </h1>
    </div>
    <div class="d-flex gap-2">
        @if (ViewBag.CategoryId != null)
        {
            <a asp-controller="Categories" asp-action="Details" asp-route-id="@ViewBag.CategoryId" class="btn btn-outline-secondary">← Категорія</a>
        }
        <a asp-action="Create" asp-route-categoryId="@ViewBag.CategoryId" class="btn btn-primary">+ Новий тест</a>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>Категорія</th>
            <th>@Html.DisplayNameFor(model => model.Words)</th>
            <th>@Html.DisplayNameFor(model => model.TimeLimitSeconds)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Title</strong></td>
                <td>
                    <a asp-controller="Categories" asp-action="Details" asp-route-id="@item.CategoryId">
                        @item.Category?.Name
                    </a>
                </td>
                <td>@item.Words</td>
                <td>@(item.TimeLimitSeconds.HasValue ? $"{item.TimeLimitSeconds} сек" : "—")</td>
                <td>
                    <a asp-controller="Tests" asp-action="Take" asp-route-id="@item.Id" class="btn btn-sm btn-success">▶ Пройти</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>
